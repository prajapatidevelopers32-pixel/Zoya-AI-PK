rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity-specific validations
    function isValidSession(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 1000
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'sender', 'text', 'createdAt'])
        && data.keys().size() == 4
        && data.id is string && data.id.size() <= 128
        && data.sender is string && (data.sender == 'user' || data.sender == 'zoya')
        && data.text is string && data.text.size() <= 10000
        && data.createdAt is timestamp;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'name', 'age', 'email', 'createdAt', 'updatedAt'])
        && data.keys().size() == 6
        && data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.age is int && data.age >= 16 && data.age <= 120
        && data.email is string && data.email.size() <= 200
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'content', 'category', 'createdAt', 'updatedAt'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 100000
        && data.category is string && data.category.size() <= 50
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Users Match Block
    match /users/{userId} {
      allow get: if isSignedIn()
        && isValidId(userId)
        && userId == request.auth.uid;

      allow create: if isSignedIn()
        && isValidId(userId)
        && userId == request.auth.uid
        && isValidUserProfile(incoming());

      allow update: if isSignedIn()
        && isValidId(userId)
        && userId == request.auth.uid
        && isValidUserProfile(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt;

      allow delete: if false;
    }

    // Sessions Match Block
    match /sessions/{sessionId} {
      allow get: if isEmailVerified() 
        && isValidId(sessionId)
        && existing().userId == request.auth.uid;

      allow list: if isEmailVerified()
        && resource.data.userId == request.auth.uid;

      allow create: if isEmailVerified()
        && isValidId(sessionId)
        && isValidSession(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isEmailVerified()
        && isValidId(sessionId)
        && isValidSession(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']);

      allow delete: if isEmailVerified()
        && isValidId(sessionId)
        && existing().userId == request.auth.uid;

      // Messages Subcollection Match Block
      match /messages/{messageId} {
        allow get: if isEmailVerified()
          && isValidId(sessionId)
          && isValidId(messageId)
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;

        allow list: if isEmailVerified()
          && isValidId(sessionId)
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;

        allow create: if isEmailVerified()
          && isValidId(sessionId)
          && isValidId(messageId)
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid
          && isValidMessage(incoming())
          && incoming().createdAt == request.time;

        // Messages are immutable after creation
        allow update, delete: if false;
      }
    }

    // Notes Match Block
    match /notes/{noteId} {
      allow get: if isEmailVerified()
        && isValidId(noteId)
        && existing().userId == request.auth.uid;

      allow list: if isEmailVerified()
        && resource.data.userId == request.auth.uid;

      allow create: if isEmailVerified()
        && isValidId(noteId)
        && isValidNote(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isEmailVerified()
        && isValidId(noteId)
        && isValidNote(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'updatedAt']);

      allow delete: if isEmailVerified()
        && isValidId(noteId)
        && existing().userId == request.auth.uid;
    }
  }
}
